  } ]
}, {
  "@id" : "https://dataout.org/ontology#SourceCategoryScheme",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2004/02/skos/core#ConceptScheme"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Source Categories"
  } ]
}, {
  "@id" : "https://dataout.org/ontology#TriggerObject",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A trigger object is an information object or public action that was used by the authorities as a reason to initiate an administrative or criminal proceeding. For example, in our monitoring of administrative persecution targeting LGBTQIA+ expression in Russia, a trigger object could be a mass media publication, which the Russian mass media regulator (Roskomnadzor) found to be violating, which resulted in a court case against a media company dissimianting such publication."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Trigger Object"
  } ]
}, {
  "@id" : "https://dataout.org/ontology#TriggerObjectCategoryScheme",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2004/02/skos/core#ConceptScheme"
  } ],
  "http://www.w3.org/2004/02/skos/core#note" : [ {
    "@language" : "en",
    "@value" : "Categories of objects that triggered administrative or criminal proceedings"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Trigger Object Categories"
  } ]
}, {
