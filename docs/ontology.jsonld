}, {
  "@id" : "https://dataout.org/",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/ns/prov#Organization"
  }, {
    "@id" : "https://schema.org/NGO"
  } ],
  "https://schema.org/address" : [ {
    "@language" : "en",
    "@value" : "The Hague, the Netherlands"
  } ],
  "https://schema.org/alternateName" : [ {
    "@language" : "en",
    "@value" : "Dataout"
  } ],
  "https://schema.org/description" : [ {
    "@language" : "en",
    "@value" : "Dataout is a nonprofit dedicated to uncovering discrimination and crimes based on SOGIESC – sexual orientation, gender identity & expression, and sex characteristics. By conducting research and releasing open data, we aim to empower journalists, researchers, human rights advocates, and policymakers in creating a better social and legal environment for LGBTQIA+ people and others affected by SOGIESC-based discrimination. We focus on the regions where these issues are severe and least visible."
  } ],
  "https://schema.org/email" : [ {
    "@id" : "mailto:contact@dataout.org"
  } ],
  "https://schema.org/legalName" : [ {
    "@language" : "en",
    "@value" : "Dataout Foundation"
  }, {
    "@language" : "nl",
    "@value" : "Stichting Dataout"
  } ],
  "https://schema.org/name" : [ {
    "@language" : "en",
    "@value" : "Dataout Foundation"
  } ],
  "https://schema.org/url" : [ {
    "@id" : "https://dataout.org/"
  } ]
}, {
  "@id" : "https://dataout.org/ontology#",
  "@type" : [ "http://www.w3.org/2002/07/owl#Ontology" ],
  "http://purl.org/dc/terms/created" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#date",
    "@value" : "2026-07-16"
  } ],
  "http://purl.org/dc/terms/creator" : [ {
    "@id" : "https://dataout.org/"
  } ],
  "http://purl.org/dc/terms/description" : [ {
    "@language" : "en",
    "@value" : "This ontology is intended to represent data on SOGIESC-based crimes and discrimination, as well as processes associated with the collection of such data. The idea behind the Dataout Ontology is to represent instances of human rights violations as phenomena that may be observed in different sources, such as court cases or mass-media publications. There are two main components: the provenance information of an incident and its content. Each observed incident is modelled as an instance of Monitoring Record, resulting from Monitoring Activity. A monitoring record connects to the content and metadata of an incident. There are also controlled vocabularies intended for categorising instances. This ontology introduces custom classes and properties and reuses the PROV Ontology, Schema.org, and DCMI Metadata Terms."
  } ],
  "http://purl.org/dc/terms/license" : [ {
    "@id" : "https://creativecommons.org/licenses/by/4.0/"
  } ],
  "http://purl.org/ontology/bibo/doi" : [ {
    "@value" : "10.5281/zenodo.21393602"
  } ],
  "http://purl.org/vocab/vann/preferredNamespacePrefix" : [ {
    "@language" : "en",
    "@value" : "dataout"
  } ],
  "http://purl.org/vocab/vann/preferredNamespaceUri" : [ {
    "@id" : "https://dataout.org/ontology#"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Dataout Ontology"
  } ],
  "http://www.w3.org/2002/07/owl#versionIRI" : [ {
    "@id" : "https://raw.githubusercontent.com/dataout-org/ontology/v1.0.0/ontology.ttl"
  } ],
  "http://www.w3.org/2002/07/owl#versionInfo" : [ {
    "@language" : "en",
    "@value" : "1.0.0"
  } ],
  "https://schema.org/image" : [ {
    "@id" : "https://github.com/dataout-org/ontology/blob/main/ontology_scheme.png?raw=true"
  } ]
