    <!-- http://purl.org/dc/terms/description -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/description"/>
    


    <!-- http://purl.org/dc/terms/license -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/license"/>
    


    <!-- http://purl.org/ontology/bibo/doi -->


    <owl:AnnotationProperty rdf:about="http://purl.org/ontology/bibo/doi"/>
    


    <!-- http://purl.org/vocab/vann/preferredNamespacePrefix -->


    <owl:AnnotationProperty rdf:about="http://purl.org/vocab/vann/preferredNamespacePrefix"/>
    


    <!-- http://purl.org/vocab/vann/preferredNamespaceUri -->


    <owl:AnnotationProperty rdf:about="http://purl.org/vocab/vann/preferredNamespaceUri"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#broader -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#broader"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#closeMatch -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#closeMatch"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#exactMatch -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#exactMatch"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#inScheme -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#inScheme"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#narrower -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#narrower"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#note -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#note"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#prefLabel -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#prefLabel"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#relatedMatch -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#relatedMatch"/>
    


    <!-- https://schema.org/address -->


    <owl:AnnotationProperty rdf:about="https://schema.org/address"/>
    


    <!-- https://schema.org/alternateName -->


    <owl:AnnotationProperty rdf:about="https://schema.org/alternateName"/>
    


    <!-- https://schema.org/description -->


    <owl:AnnotationProperty rdf:about="https://schema.org/description"/>
    


    <!-- https://schema.org/email -->


    <owl:AnnotationProperty rdf:about="https://schema.org/email"/>
    


    <!-- https://schema.org/image -->


    <owl:AnnotationProperty rdf:about="https://schema.org/image"/>
    


    <!-- https://schema.org/legalName -->


    <owl:AnnotationProperty rdf:about="https://schema.org/legalName"/>
    


    <!-- https://schema.org/name -->


    <owl:AnnotationProperty rdf:about="https://schema.org/name"/>
    


    <!-- https://schema.org/url -->


    <owl:AnnotationProperty rdf:about="https://schema.org/url"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Datatypes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.w3.org/2001/XMLSchema#date -->


    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#date"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- https://dataout.org/ontology#concernsLegalArticle -->


    <owl:ObjectProperty rdf:about="https://dataout.org/ontology#concernsLegalArticle">
        <rdfs:domain rdf:resource="https://dataout.org/ontology#MonitoringRecord"/>
        <rdfs:range rdf:resource="https://schema.org/Legislation"/>
        <rdfs:comment xml:lang="en">Connect a monitoring record to a legal article. Useful when monitoring state persecution.</rdfs:comment>
        <rdfs:label xml:lang="en">concerns legal article</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://dataout.org/ontology#defendantCategory -->


    <owl:ObjectProperty rdf:about="https://dataout.org/ontology#defendantCategory">
        <rdfs:domain rdf:resource="https://dataout.org/ontology#Defendant"/>
        <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdfs:comment xml:lang="en">Connects a defendant to its category.</rdfs:comment>
        <rdfs:label xml:lang="en">defendant category</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://dataout.org/ontology#hasDefendant -->


    <owl:ObjectProperty rdf:about="https://dataout.org/ontology#hasDefendant">
        <rdfs:domain rdf:resource="https://dataout.org/ontology#MonitoringRecord"/>
        <rdfs:range rdf:resource="https://dataout.org/ontology#Defendant"/>
        <rdfs:comment xml:lang="en">A natural person or legal entity, which is referred to as a defendant in a source documents (for example, a court decision or a mass media publication).</rdfs:comment>
        <rdfs:label xml:lang="en">has defendant</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://dataout.org/ontology#hasPenalty -->


    <owl:ObjectProperty rdf:about="https://dataout.org/ontology#hasPenalty">
        <rdfs:domain rdf:resource="https://dataout.org/ontology#MonitoringRecord"/>
        <rdfs:range rdf:resource="https://dataout.org/ontology#Penalty"/>
        <rdfs:comment xml:lang="en">Connects a penalty imposed on a defendant by an official body (a court) to a monitoring record, in which it was mentioned.</rdfs:comment>
        <rdfs:label xml:lang="en">has penalty</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://dataout.org/ontology#hasTriggerObject -->


    <owl:ObjectProperty rdf:about="https://dataout.org/ontology#hasTriggerObject">
        <rdfs:domain rdf:resource="https://dataout.org/ontology#MonitoringRecord"/>
        <rdfs:range rdf:resource="https://dataout.org/ontology#TriggerObject"/>
        <rdfs:comment xml:lang="en">Connects a trigger object to a monitoring record, in which it was mentioned.</rdfs:comment>
        <rdfs:label xml:lang="en">has trigger object</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://dataout.org/ontology#mentionedIn -->


    <owl:ObjectProperty rdf:about="https://dataout.org/ontology#mentionedIn">
        <rdfs:domain rdf:resource="https://dataout.org/ontology#MonitoringRecord"/>
        <rdfs:range rdf:resource="https://dataout.org/ontology#Source"/>
        <rdfs:comment xml:lang="en">Used to connect a monitoring record to a source that mentions some information about a monitoring record.</rdfs:comment>
        <rdfs:label xml:lang="en">mentioned in</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://dataout.org/ontology#monitoringCategory -->


    <owl:ObjectProperty rdf:about="https://dataout.org/ontology#monitoringCategory">
        <rdfs:domain rdf:resource="https://dataout.org/ontology#MonitoringActivity"/>
        <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdfs:comment xml:lang="en">Connects a monitoring activity to its category.</rdfs:comment>
        <rdfs:label xml:lang="en">category of monitoring</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://dataout.org/ontology#penaltyCategory -->


    <owl:ObjectProperty rdf:about="https://dataout.org/ontology#penaltyCategory">
        <rdfs:domain rdf:resource="https://dataout.org/ontology#Penalty"/>
        <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdfs:comment xml:lang="en">Connects a penalty to its category.</rdfs:comment>
        <rdfs:label xml:lang="en">penalty category</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://dataout.org/ontology#penaltyValue -->


    <owl:ObjectProperty rdf:about="https://dataout.org/ontology#penaltyValue">
        <rdfs:domain rdf:resource="https://dataout.org/ontology#Penalty"/>
        <rdfs:range rdf:resource="https://schema.org/StructuredValue"/>
        <rdfs:comment xml:lang="en">Connects a penalty to its value. The value of this property can be a triple, which indicates its quantitative unit (such as a monetary amount or days) and amount. For example, a penalty value could be a quantitative unit of 10 days if the penalty category is detention.</rdfs:comment>
        <rdfs:label xml:lang="en">penalty value</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://dataout.org/ontology#sourceCategory -->


    <owl:ObjectProperty rdf:about="https://dataout.org/ontology#sourceCategory">
        <rdfs:domain rdf:resource="https://dataout.org/ontology#Source"/>
        <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdfs:comment xml:lang="en">Connects a source to its category.</rdfs:comment>
        <rdfs:label xml:lang="en">source category</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://dataout.org/ontology#triggerObjectCategory -->


    <owl:ObjectProperty rdf:about="https://dataout.org/ontology#triggerObjectCategory">
        <rdfs:domain rdf:resource="https://dataout.org/ontology#TriggerObject"/>
        <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdfs:comment xml:lang="en">Categories of trigger objects describe what such object is (for example, a film, a social media post, a protest), but not its legal interpretation by authorities.</rdfs:comment>
        <rdfs:label xml:lang="en">trigger object category</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://purl.org/dc/terms/date -->


    <owl:DatatypeProperty rdf:about="http://purl.org/dc/terms/date"/>
    


    <!-- http://purl.org/dc/terms/identifier -->


    <owl:DatatypeProperty rdf:about="http://purl.org/dc/terms/identifier"/>
    


    <!-- https://dataout.org/ontology#courtCode -->


    <owl:DatatypeProperty rdf:about="https://dataout.org/ontology#courtCode">
        <rdfs:subPropertyOf rdf:resource="http://purl.org/dc/terms/identifier"/>
        <rdfs:domain rdf:resource="https://dataout.org/ontology#Court"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="en">An identifier code assigned to a court by a judicial or administrative authority.</rdfs:comment>
        <rdfs:label xml:lang="en">court code</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://dataout.org/ontology#courtDocumentDate -->


    <owl:DatatypeProperty rdf:about="https://dataout.org/ontology#courtDocumentDate">
        <rdfs:subPropertyOf rdf:resource="http://purl.org/dc/terms/date"/>
        <rdfs:domain rdf:resource="https://dataout.org/ontology#Source"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="en">Indicates a date stated on a court document.</rdfs:comment>
        <rdfs:label xml:lang="en">court document date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://dataout.org/ontology#courtDocumentNumber -->


    <owl:DatatypeProperty rdf:about="https://dataout.org/ontology#courtDocumentNumber">
        <rdfs:subPropertyOf rdf:resource="http://purl.org/dc/terms/identifier"/>
        <rdfs:domain rdf:resource="https://dataout.org/ontology#Source"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="en">Used to indicate a number of a court document assigned by court. It is not necessarily a unique identifier. To indicate unique identifiers, use uniqueCourtDocumentID.</rdfs:comment>
        <rdfs:label xml:lang="en">court document number</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://dataout.org/ontology#hasSnippet -->


    <owl:DatatypeProperty rdf:about="https://dataout.org/ontology#hasSnippet">
        <rdfs:domain rdf:resource="https://dataout.org/ontology#MonitoringRecord"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="en">Connects a monitoring record to its textual summary (a snippet).</rdfs:comment>
        <rdfs:label xml:lang="en">has snippet</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://dataout.org/ontology#monitoredIncidentYear -->


    <owl:DatatypeProperty rdf:about="https://dataout.org/ontology#monitoredIncidentYear">
        <rdfs:domain rdf:resource="https://dataout.org/ontology#MonitoringRecord"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="en">We categorise monitored incidents by year, during which they occured. This property represents years of incidents.</rdfs:comment>
        <rdfs:label xml:lang="en">monitored incident year</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://dataout.org/ontology#monitoringRecordNumber -->


    <owl:DatatypeProperty rdf:about="https://dataout.org/ontology#monitoringRecordNumber">
        <rdfs:subPropertyOf rdf:resource="http://purl.org/dc/terms/identifier"/>
        <rdfs:domain rdf:resource="https://dataout.org/ontology#MonitoringRecord"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="en">A unique identifier assigned to a monitoring record within the Dataout monitoring system.</rdfs:comment>
        <rdfs:label xml:lang="en">monitoring record number</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://dataout.org/ontology#uniqueCourtDocumentID -->


    <owl:DatatypeProperty rdf:about="https://dataout.org/ontology#uniqueCourtDocumentID">
        <rdfs:subPropertyOf rdf:resource="http://purl.org/dc/terms/identifier"/>
        <rdfs:domain rdf:resource="https://dataout.org/ontology#Source"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="en">Unique court document ID assigned by court.</rdfs:comment>
        <rdfs:label xml:lang="en">unique court document ID</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.w3.org/2004/02/skos/core#Concept -->


    <owl:Class rdf:about="http://www.w3.org/2004/02/skos/core#Concept"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#ConceptScheme -->


    <owl:Class rdf:about="http://www.w3.org/2004/02/skos/core#ConceptScheme"/>
    


    <!-- http://www.w3.org/ns/prov#Activity -->


    <owl:Class rdf:about="http://www.w3.org/ns/prov#Activity"/>
    


    <!-- http://www.w3.org/ns/prov#Entity -->


    <owl:Class rdf:about="http://www.w3.org/ns/prov#Entity"/>
    


    <!-- http://www.w3.org/ns/prov#Organization -->


    <owl:Class rdf:about="http://www.w3.org/ns/prov#Organization"/>
    


    <!-- https://dataout.org/ontology#Court -->


    <owl:Class rdf:about="https://dataout.org/ontology#Court">
        <rdfs:subClassOf rdf:resource="https://schema.org/Organization"/>
        <rdfs:comment xml:lang="en">Class representing a court of any level.</rdfs:comment>
        <rdfs:label xml:lang="en">Court</rdfs:label>
    </owl:Class>
    


    <!-- https://dataout.org/ontology#Defendant -->


    <owl:Class rdf:about="https://dataout.org/ontology#Defendant">
        <rdfs:comment xml:lang="en">A legal or natural person with a role of a defendant in a legal process.</rdfs:comment>
        <rdfs:label xml:lang="en">Defendant</rdfs:label>
    </owl:Class>
    


    <!-- https://dataout.org/ontology#MonitoringActivity -->


    <owl:Class rdf:about="https://dataout.org/ontology#MonitoringActivity">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Activity"/>
        <rdfs:comment xml:lang="en">Class representing a single monitoring activity. Dataout conducts monitorings of different categories, such as hate crimes, discrimination, administrative and criminal persecution. The categories of monitoring are defined by the MonitoringCategoryScheme.</rdfs:comment>
        <rdfs:label xml:lang="en">Monitoring Activity</rdfs:label>
    </owl:Class>
    


    <!-- https://dataout.org/ontology#MonitoringRecord -->


    <owl:Class rdf:about="https://dataout.org/ontology#MonitoringRecord">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Entity"/>
        <rdfs:comment xml:lang="en">A single record resulting from a monitoring activity. For example, if a monitoring activity documents hate crime incidents, an entity representing a hate crime would be a monitoring record.</rdfs:comment>
        <rdfs:label xml:lang="en">Monitoring Record</rdfs:label>
    </owl:Class>
    


    <!-- https://dataout.org/ontology#Penalty -->


    <owl:Class rdf:about="https://dataout.org/ontology#Penalty">
        <rdfs:comment xml:lang="en">Penalty imposed by an official body, such as a court.</rdfs:comment>
        <rdfs:label xml:lang="en">Penalty</rdfs:label>
    </owl:Class>
    


    <!-- https://dataout.org/ontology#Source -->


    <owl:Class rdf:about="https://dataout.org/ontology#Source">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Entity"/>
        <rdfs:comment xml:lang="en">A source of a monitoring record indicating provenance information.</rdfs:comment>
        <rdfs:label xml:lang="en">Source</rdfs:label>
    </owl:Class>
    


    <!-- https://dataout.org/ontology#TriggerObject -->


    <owl:Class rdf:about="https://dataout.org/ontology#TriggerObject">
        <rdfs:comment xml:lang="en">A trigger object is an information object or public action that was used by the authorities as a reason to initiate an administrative or criminal proceeding. For example, in our monitoring of administrative persecution targeting LGBTQIA+ expression in Russia, a trigger object could be a mass media publication, which the Russian mass media regulator (Roskomnadzor) found to be violating, which resulted in a court case against a media company dissimianting such publication.</rdfs:comment>
        <rdfs:label xml:lang="en">Trigger Object</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.org/Legislation -->


    <owl:Class rdf:about="https://schema.org/Legislation"/>
    


    <!-- https://schema.org/NGO -->


    <owl:Class rdf:about="https://schema.org/NGO"/>
    


    <!-- https://schema.org/Organization -->


    <owl:Class rdf:about="https://schema.org/Organization"/>
    


    <!-- https://schema.org/StructuredValue -->


    <owl:Class rdf:about="https://schema.org/StructuredValue"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Individuals
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- https://dataout.org/ -->


    <owl:NamedIndividual rdf:about="https://dataout.org/">
        <rdf:type rdf:resource="http://www.w3.org/ns/prov#Organization"/>
        <rdf:type rdf:resource="https://schema.org/NGO"/>
        <schema:address xml:lang="en">The Hague, the Netherlands</schema:address>
        <schema:alternateName xml:lang="en">Dataout</schema:alternateName>
        <schema:description xml:lang="en">Dataout is a nonprofit dedicated to uncovering discrimination and crimes based on SOGIESC – sexual orientation, gender identity &amp; expression, and sex characteristics. By conducting research and releasing open data, we aim to empower journalists, researchers, human rights advocates, and policymakers in creating a better social and legal environment for LGBTQIA+ people and others affected by SOGIESC-based discrimination. We focus on the regions where these issues are severe and least visible.</schema:description>
        <schema:email rdf:resource="mailto:contact@dataout.org"/>
        <schema:legalName xml:lang="en">Dataout Foundation</schema:legalName>
        <schema:legalName xml:lang="nl">Stichting Dataout</schema:legalName>
        <schema:name xml:lang="en">Dataout Foundation</schema:name>
        <schema:url rdf:resource="https://dataout.org/"/>
    </owl:NamedIndividual>
    


    <!-- https://dataout.org/ontology#DefendantCategoryScheme -->


    <owl:NamedIndividual rdf:about="https://dataout.org/ontology#DefendantCategoryScheme">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#ConceptScheme"/>
        <skos:prefLabel xml:lang="en">Defendant Categories</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://dataout.org/ontology#LegislationCategoryScheme -->


    <owl:NamedIndividual rdf:about="https://dataout.org/ontology#LegislationCategoryScheme">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#ConceptScheme"/>
        <skos:prefLabel xml:lang="en">Legislation Categories</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://dataout.org/ontology#MonitoringCategoryScheme -->


    <owl:NamedIndividual rdf:about="https://dataout.org/ontology#MonitoringCategoryScheme">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#ConceptScheme"/>
        <skos:prefLabel xml:lang="en">Monitoring Categories</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://dataout.org/ontology#PenaltyCategoryScheme -->


    <owl:NamedIndividual rdf:about="https://dataout.org/ontology#PenaltyCategoryScheme">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#ConceptScheme"/>
        <skos:prefLabel xml:lang="en">Penalty Categories</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://dataout.org/ontology#SourceCategoryScheme -->


    <owl:NamedIndividual rdf:about="https://dataout.org/ontology#SourceCategoryScheme">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#ConceptScheme"/>
        <skos:prefLabel xml:lang="en">Source Categories</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://dataout.org/ontology#TriggerObjectCategoryScheme -->


    <owl:NamedIndividual rdf:about="https://dataout.org/ontology#TriggerObjectCategoryScheme">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#ConceptScheme"/>
        <skos:note xml:lang="en">Categories of objects that triggered administrative or criminal proceedings</skos:note>
        <skos:prefLabel xml:lang="en">Trigger Object Categories</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://dataout.org/ontology#administrativeCode -->


    <owl:NamedIndividual rdf:about="https://dataout.org/ontology#administrativeCode">
