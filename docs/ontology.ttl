<https://schema.org/address> rdf:type owl:AnnotationProperty .


###  https://schema.org/alternateName
<https://schema.org/alternateName> rdf:type owl:AnnotationProperty .


###  https://schema.org/description
<https://schema.org/description> rdf:type owl:AnnotationProperty .


###  https://schema.org/email
<https://schema.org/email> rdf:type owl:AnnotationProperty .


###  https://schema.org/image
<https://schema.org/image> rdf:type owl:AnnotationProperty .


###  https://schema.org/legalName
<https://schema.org/legalName> rdf:type owl:AnnotationProperty .


###  https://schema.org/name
<https://schema.org/name> rdf:type owl:AnnotationProperty .


###  https://schema.org/url
<https://schema.org/url> rdf:type owl:AnnotationProperty .


#################################################################
#    Datatypes
#################################################################

###  http://www.w3.org/2001/XMLSchema#date
xsd:date rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  https://dataout.org/ontology#concernsLegalArticle
:concernsLegalArticle rdf:type owl:ObjectProperty ;
                      rdfs:domain :MonitoringRecord ;
                      rdfs:range <https://schema.org/Legislation> ;
                      rdfs:comment "Connect a monitoring record to a legal article. Useful when monitoring state persecution."@en ;
                      rdfs:label "concerns legal article"@en .


###  https://dataout.org/ontology#defendantCategory
:defendantCategory rdf:type owl:ObjectProperty ;
                   rdfs:domain :Defendant ;
                   rdfs:range <http://www.w3.org/2004/02/skos/core#Concept> ;
                   rdfs:comment "Connects a defendant to its category."@en ;
                   rdfs:label "defendant category"@en .


###  https://dataout.org/ontology#hasDefendant
:hasDefendant rdf:type owl:ObjectProperty ;
              rdfs:domain :MonitoringRecord ;
              rdfs:range :Defendant ;
              rdfs:comment "A natural person or legal entity, which is referred to as a defendant in a source documents (for example, a court decision or a mass media publication)."@en ;
              rdfs:label "has defendant"@en .


###  https://dataout.org/ontology#hasPenalty
:hasPenalty rdf:type owl:ObjectProperty ;
            rdfs:domain :MonitoringRecord ;
            rdfs:range :Penalty ;
            rdfs:comment "Connects a penalty imposed on a defendant by an official body (a court) to a monitoring record, in which it was mentioned."@en ;
            rdfs:label "has penalty"@en .


###  https://dataout.org/ontology#hasTriggerObject
:hasTriggerObject rdf:type owl:ObjectProperty ;
                  rdfs:domain :MonitoringRecord ;
                  rdfs:range :TriggerObject ;
                  rdfs:comment "Connects a trigger object to a monitoring record, in which it was mentioned."@en ;
                  rdfs:label "has trigger object"@en .


###  https://dataout.org/ontology#mentionedIn
:mentionedIn rdf:type owl:ObjectProperty ;
             rdfs:domain :MonitoringRecord ;
             rdfs:range :Source ;
             rdfs:comment "Used to connect a monitoring record to a source that mentions some information about a monitoring record."@en ;
             rdfs:label "mentioned in"@en .


###  https://dataout.org/ontology#monitoringCategory
:monitoringCategory rdf:type owl:ObjectProperty ;
                    rdfs:domain :MonitoringActivity ;
                    rdfs:range <http://www.w3.org/2004/02/skos/core#Concept> ;
                    rdfs:comment "Connects a monitoring activity to its category."@en ;
                    rdfs:label "category of monitoring"@en .


###  https://dataout.org/ontology#penaltyCategory
:penaltyCategory rdf:type owl:ObjectProperty ;
                 rdfs:domain :Penalty ;
                 rdfs:range <http://www.w3.org/2004/02/skos/core#Concept> ;
                 rdfs:comment "Connects a penalty to its category."@en ;
                 rdfs:label "penalty category"@en .


###  https://dataout.org/ontology#penaltyValue
:penaltyValue rdf:type owl:ObjectProperty ;
              rdfs:domain :Penalty ;
              rdfs:range <https://schema.org/StructuredValue> ;
              rdfs:comment "Connects a penalty to its value. The value of this property can be a triple, which indicates its quantitative unit (such as a monetary amount or days) and amount. For example, a penalty value could be a quantitative unit of 10 days if the penalty category is detention."@en ;
              rdfs:label "penalty value"@en .


###  https://dataout.org/ontology#sourceCategory
:sourceCategory rdf:type owl:ObjectProperty ;
                rdfs:domain :Source ;
                rdfs:range <http://www.w3.org/2004/02/skos/core#Concept> ;
                rdfs:comment "Connects a source to its category."@en ;
                rdfs:label "source category"@en .


###  https://dataout.org/ontology#triggerObjectCategory
:triggerObjectCategory rdf:type owl:ObjectProperty ;
                       rdfs:domain :TriggerObject ;
                       rdfs:range <http://www.w3.org/2004/02/skos/core#Concept> ;
                       rdfs:comment "Categories of trigger objects describe what such object is (for example, a film, a social media post, a protest), but not its legal interpretation by authorities."@en ;
                       rdfs:label "trigger object category"@en .


#################################################################
#    Data properties
#################################################################

###  http://purl.org/dc/terms/date
<http://purl.org/dc/terms/date> rdf:type owl:DatatypeProperty .


###  http://purl.org/dc/terms/identifier
<http://purl.org/dc/terms/identifier> rdf:type owl:DatatypeProperty .


###  https://dataout.org/ontology#courtCode
:courtCode rdf:type owl:DatatypeProperty ;
           rdfs:subPropertyOf <http://purl.org/dc/terms/identifier> ;
           rdfs:domain :Court ;
           rdfs:range rdfs:Literal ;
           rdfs:comment "An identifier code assigned to a court by a judicial or administrative authority."@en ;
           rdfs:label "court code"@en .


###  https://dataout.org/ontology#courtDocumentDate
:courtDocumentDate rdf:type owl:DatatypeProperty ;
                   rdfs:subPropertyOf <http://purl.org/dc/terms/date> ;
                   rdfs:domain :Source ;
                   rdfs:range rdfs:Literal ;
                   rdfs:comment "Indicates a date stated on a court document."@en ;
                   rdfs:label "court document date"@en .


###  https://dataout.org/ontology#courtDocumentNumber
:courtDocumentNumber rdf:type owl:DatatypeProperty ;
                     rdfs:subPropertyOf <http://purl.org/dc/terms/identifier> ;
                     rdfs:domain :Source ;
                     rdfs:range rdfs:Literal ;
                     rdfs:comment "Used to indicate a number of a court document assigned by court. It is not necessarily a unique identifier. To indicate unique identifiers, use uniqueCourtDocumentID."@en ;
                     rdfs:label "court document number"@en .


###  https://dataout.org/ontology#hasSnippet
:hasSnippet rdf:type owl:DatatypeProperty ;
            rdfs:domain :MonitoringRecord ;
            rdfs:range rdfs:Literal ;
            rdfs:comment "Connects a monitoring record to its textual summary (a snippet)."@en ;
            rdfs:label "has snippet"@en .


###  https://dataout.org/ontology#monitoredIncidentYear
:monitoredIncidentYear rdf:type owl:DatatypeProperty ;
                       rdfs:domain :MonitoringRecord ;
                       rdfs:range rdfs:Literal ;
                       rdfs:comment "We categorise monitored incidents by year, during which they occured. This property represents years of incidents."@en ;
                       rdfs:label "monitored incident year"@en .


###  https://dataout.org/ontology#monitoringRecordNumber
:monitoringRecordNumber rdf:type owl:DatatypeProperty ;
                        rdfs:subPropertyOf <http://purl.org/dc/terms/identifier> ;
                        rdfs:domain :MonitoringRecord ;
                        rdfs:range rdfs:Literal ;
                        rdfs:comment "A unique identifier assigned to a monitoring record within the Dataout monitoring system."@en ;
                        rdfs:label "monitoring record number"@en .


###  https://dataout.org/ontology#uniqueCourtDocumentID
:uniqueCourtDocumentID rdf:type owl:DatatypeProperty ;
                       rdfs:subPropertyOf <http://purl.org/dc/terms/identifier> ;
                       rdfs:domain :Source ;
                       rdfs:range rdfs:Literal ;
                       rdfs:comment "Unique court document ID assigned by court."@en ;
                       rdfs:label "unique court document ID"@en .


#################################################################
#    Classes
#################################################################

###  http://www.w3.org/2004/02/skos/core#Concept
<http://www.w3.org/2004/02/skos/core#Concept> rdf:type owl:Class .


###  http://www.w3.org/2004/02/skos/core#ConceptScheme
<http://www.w3.org/2004/02/skos/core#ConceptScheme> rdf:type owl:Class .


###  http://www.w3.org/ns/prov#Activity
<http://www.w3.org/ns/prov#Activity> rdf:type owl:Class .


###  http://www.w3.org/ns/prov#Entity
<http://www.w3.org/ns/prov#Entity> rdf:type owl:Class .


###  http://www.w3.org/ns/prov#Organization
<http://www.w3.org/ns/prov#Organization> rdf:type owl:Class .


###  https://dataout.org/ontology#Court
:Court rdf:type owl:Class ;
       rdfs:subClassOf <https://schema.org/Organization> ;
       rdfs:comment "Class representing a court of any level."@en ;
       rdfs:label "Court"@en .


###  https://dataout.org/ontology#Defendant
:Defendant rdf:type owl:Class ;
           rdfs:comment "A legal or natural person with a role of a defendant in a legal process."@en ;
           rdfs:label "Defendant"@en .


###  https://dataout.org/ontology#MonitoringActivity
:MonitoringActivity rdf:type owl:Class ;
                    rdfs:subClassOf <http://www.w3.org/ns/prov#Activity> ;
                    rdfs:comment "Class representing a single monitoring activity. Dataout conducts monitorings of different categories, such as hate crimes, discrimination, administrative and criminal persecution. The categories of monitoring are defined by the MonitoringCategoryScheme."@en ;
                    rdfs:label "Monitoring Activity"@en .


###  https://dataout.org/ontology#MonitoringRecord
:MonitoringRecord rdf:type owl:Class ;
                  rdfs:subClassOf <http://www.w3.org/ns/prov#Entity> ;
                  rdfs:comment "A single record resulting from a monitoring activity. For example, if a monitoring activity documents hate crime incidents, an entity representing a hate crime would be a monitoring record."@en ;
                  rdfs:label "Monitoring Record"@en .


###  https://dataout.org/ontology#Penalty
:Penalty rdf:type owl:Class ;
         rdfs:comment "Penalty imposed by an official body, such as a court."@en ;
         rdfs:label "Penalty"@en .


###  https://dataout.org/ontology#Source
:Source rdf:type owl:Class ;
        rdfs:subClassOf <http://www.w3.org/ns/prov#Entity> ;
        rdfs:comment "A source of a monitoring record indicating provenance information."@en ;
        rdfs:label "Source"@en .


###  https://dataout.org/ontology#TriggerObject
:TriggerObject rdf:type owl:Class ;
               rdfs:comment "A trigger object is an information object or public action that was used by the authorities as a reason to initiate an administrative or criminal proceeding. For example, in our monitoring of administrative persecution targeting LGBTQIA+ expression in Russia, a trigger object could be a mass media publication, which the Russian mass media regulator (Roskomnadzor) found to be violating, which resulted in a court case against a media company dissimianting such publication."@en ;
               rdfs:label "Trigger Object"@en .


###  https://schema.org/Legislation
<https://schema.org/Legislation> rdf:type owl:Class .


###  https://schema.org/NGO
<https://schema.org/NGO> rdf:type owl:Class .


###  https://schema.org/Organization
<https://schema.org/Organization> rdf:type owl:Class .


###  https://schema.org/StructuredValue
<https://schema.org/StructuredValue> rdf:type owl:Class .


#################################################################
#    Individuals
#################################################################

###  https://dataout.org/
<https://dataout.org/> rdf:type owl:NamedIndividual ,
                                <http://www.w3.org/ns/prov#Organization> ,
                                <https://schema.org/NGO> ;
                       <https://schema.org/address> "The Hague, the Netherlands"@en ;
                       <https://schema.org/alternateName> "Dataout"@en ;
                       <https://schema.org/description> "Dataout is a nonprofit dedicated to uncovering discrimination and crimes based on SOGIESC – sexual orientation, gender identity & expression, and sex characteristics. By conducting research and releasing open data, we aim to empower journalists, researchers, human rights advocates, and policymakers in creating a better social and legal environment for LGBTQIA+ people and others affected by SOGIESC-based discrimination. We focus on the regions where these issues are severe and least visible."@en ;
                       <https://schema.org/email> <mailto:contact@dataout.org> ;
                       <https://schema.org/legalName> "Dataout Foundation"@en ,
                                                      "Stichting Dataout"@nl ;
                       <https://schema.org/name> "Dataout Foundation"@en ;
                       <https://schema.org/url> <https://dataout.org/> .


###  https://dataout.org/ontology#DefendantCategoryScheme
:DefendantCategoryScheme rdf:type owl:NamedIndividual ,
                                  <http://www.w3.org/2004/02/skos/core#ConceptScheme> ;
                         <http://www.w3.org/2004/02/skos/core#prefLabel> "Defendant Categories"@en .


###  https://dataout.org/ontology#LegislationCategoryScheme
:LegislationCategoryScheme rdf:type owl:NamedIndividual ,
                                    <http://www.w3.org/2004/02/skos/core#ConceptScheme> ;
                           <http://www.w3.org/2004/02/skos/core#prefLabel> "Legislation Categories"@en .


###  https://dataout.org/ontology#MonitoringCategoryScheme
:MonitoringCategoryScheme rdf:type owl:NamedIndividual ,
                                   <http://www.w3.org/2004/02/skos/core#ConceptScheme> ;
                          <http://www.w3.org/2004/02/skos/core#prefLabel> "Monitoring Categories"@en .


###  https://dataout.org/ontology#PenaltyCategoryScheme
:PenaltyCategoryScheme rdf:type owl:NamedIndividual ,
                                <http://www.w3.org/2004/02/skos/core#ConceptScheme> ;
                       <http://www.w3.org/2004/02/skos/core#prefLabel> "Penalty Categories"@en .


###  https://dataout.org/ontology#SourceCategoryScheme
:SourceCategoryScheme rdf:type owl:NamedIndividual ,
                               <http://www.w3.org/2004/02/skos/core#ConceptScheme> ;
                      <http://www.w3.org/2004/02/skos/core#prefLabel> "Source Categories"@en .


###  https://dataout.org/ontology#TriggerObjectCategoryScheme
:TriggerObjectCategoryScheme rdf:type owl:NamedIndividual ,
                                      <http://www.w3.org/2004/02/skos/core#ConceptScheme> ;
                             <http://www.w3.org/2004/02/skos/core#note> "Categories of objects that triggered administrative or criminal proceedings"@en ;
                             <http://www.w3.org/2004/02/skos/core#prefLabel> "Trigger Object Categories"@en .


###  https://dataout.org/ontology#administrativeCode
:administrativeCode rdf:type owl:NamedIndividual ,
                             <http://www.w3.org/2004/02/skos/core#Concept> ;
                    <http://www.w3.org/2004/02/skos/core#inScheme> :LegislationCategoryScheme ;
                    <http://www.w3.org/2004/02/skos/core#prefLabel> "Administrative Code"@en .


###  https://dataout.org/ontology#administrativePersecution
:administrativePersecution rdf:type owl:NamedIndividual ,
                                    <http://www.w3.org/2004/02/skos/core#Concept> ;
                           <http://www.w3.org/2004/02/skos/core#inScheme> :MonitoringCategoryScheme ;
                           <http://www.w3.org/2004/02/skos/core#prefLabel> "Administrative persecution"@en .


###  https://dataout.org/ontology#book
:book rdf:type owl:NamedIndividual ,
               <http://www.w3.org/2004/02/skos/core#Concept> ;
      <http://www.w3.org/2004/02/skos/core#exactMatch> <https://schema.org/Book> ;
      <http://www.w3.org/2004/02/skos/core#inScheme> :TriggerObjectCategoryScheme ;
      <http://www.w3.org/2004/02/skos/core#narrower> :comicBook ;
      <http://www.w3.org/2004/02/skos/core#prefLabel> "Book"@en .


###  https://dataout.org/ontology#comicBook
:comicBook rdf:type owl:NamedIndividual ,
                    <http://www.w3.org/2004/02/skos/core#Concept> ;
           <http://www.w3.org/2004/02/skos/core#broader> :book ;
           <http://www.w3.org/2004/02/skos/core#exactMatch> <https://www.wikidata.org/wiki/Q1760610> ;
           <http://www.w3.org/2004/02/skos/core#inScheme> :TriggerObjectCategoryScheme ;
           <http://www.w3.org/2004/02/skos/core#prefLabel> "Comics"@en .


###  https://dataout.org/ontology#constitution
:constitution rdf:type owl:NamedIndividual ,
                       <http://www.w3.org/2004/02/skos/core#Concept> ;
              <http://www.w3.org/2004/02/skos/core#inScheme> :LegislationCategoryScheme ;
              <http://www.w3.org/2004/02/skos/core#prefLabel> "Constitution"@en .


###  https://dataout.org/ontology#courtDocument
:courtDocument rdf:type owl:NamedIndividual ,
                        <http://www.w3.org/2004/02/skos/core#Concept> ;
               <http://www.w3.org/2004/02/skos/core#inScheme> :SourceCategoryScheme ;
               <http://www.w3.org/2004/02/skos/core#prefLabel> "Court document"@en ;
               <http://www.w3.org/2004/02/skos/core#relatedMatch> <https://www.wikidata.org/wiki/Q2334719> .


###  https://dataout.org/ontology#criminalCode
:criminalCode rdf:type owl:NamedIndividual ,
                       <http://www.w3.org/2004/02/skos/core#Concept> ;
              <http://www.w3.org/2004/02/skos/core#inScheme> :LegislationCategoryScheme ;
              <http://www.w3.org/2004/02/skos/core#prefLabel> "Criminal Code"@en .


###  https://dataout.org/ontology#criminalPersecution
:criminalPersecution rdf:type owl:NamedIndividual ,
                              <http://www.w3.org/2004/02/skos/core#Concept> ;
                     <http://www.w3.org/2004/02/skos/core#closeMatch> <https://www.wikidata.org/wiki/Q80111632> ;
                     <http://www.w3.org/2004/02/skos/core#inScheme> :MonitoringCategoryScheme ;
                     <http://www.w3.org/2004/02/skos/core#prefLabel> "Criminal persecution"@en .


###  https://dataout.org/ontology#datingProfile
:datingProfile rdf:type owl:NamedIndividual ,
                        <http://www.w3.org/2004/02/skos/core#Concept> ;
               <http://www.w3.org/2004/02/skos/core#broader> :webContent ;
               <http://www.w3.org/2004/02/skos/core#exactMatch> <https://www.wikidata.org/wiki/Q128802099> ;
               <http://www.w3.org/2004/02/skos/core#inScheme> :TriggerObjectCategoryScheme ;
               <http://www.w3.org/2004/02/skos/core#prefLabel> "Dating profile"@en .


###  https://dataout.org/ontology#detention
:detention rdf:type owl:NamedIndividual ,
                    <http://www.w3.org/2004/02/skos/core#Concept> ;
           <http://www.w3.org/2004/02/skos/core#inScheme> :PenaltyCategoryScheme ;
           <http://www.w3.org/2004/02/skos/core#prefLabel> "Detention"@en .


###  https://dataout.org/ontology#expulsion
:expulsion rdf:type owl:NamedIndividual ,
                    <http://www.w3.org/2004/02/skos/core#Concept> ;
           <http://www.w3.org/2004/02/skos/core#inScheme> :PenaltyCategoryScheme ;
           <http://www.w3.org/2004/02/skos/core#prefLabel> "Expulsion"@en .


###  https://dataout.org/ontology#federalLaw
:federalLaw rdf:type owl:NamedIndividual ,
                     <http://www.w3.org/2004/02/skos/core#Concept> ;
            <http://www.w3.org/2004/02/skos/core#inScheme> :LegislationCategoryScheme ;
            <http://www.w3.org/2004/02/skos/core#prefLabel> "Federal law"@en .


###  https://dataout.org/ontology#film
:film rdf:type owl:NamedIndividual ,
               <http://www.w3.org/2004/02/skos/core#Concept> ;
      <http://www.w3.org/2004/02/skos/core#exactMatch> <https://schema.org/Movie> ;
      <http://www.w3.org/2004/02/skos/core#inScheme> :TriggerObjectCategoryScheme ;
      <http://www.w3.org/2004/02/skos/core#prefLabel> "Film"@en .


###  https://dataout.org/ontology#fine
:fine rdf:type owl:NamedIndividual ,
               <http://www.w3.org/2004/02/skos/core#Concept> ;
      <http://www.w3.org/2004/02/skos/core#inScheme> :PenaltyCategoryScheme ;
      <http://www.w3.org/2004/02/skos/core#prefLabel> "Fine"@en .


###  https://dataout.org/ontology#hateCrimes
:hateCrimes rdf:type owl:NamedIndividual ,
